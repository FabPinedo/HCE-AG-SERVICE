# ag-pruebas-ag — API Gateway
# Generated by Jarvis Platform
# Copiar a .env y completar los valores marcados con ***

# ── Servidor ──────────────────────────────────────────────
PORT=10401
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────
# Orígenes permitidos separados por coma
# En development se acepta cualquier origen automáticamente
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:10100

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
REQUEST_TIMEOUT=120000

# ── Servicios proxiados ───────────────────────────────────
# URL del Auth Service — usada para PROXY de rutas /auth/*
AUTH_URL=http://localhost:10101
# URL del Auth Service — usada por JwtAuthGuard para validar tokens
# Normalmente el mismo valor que AUTH_URL
AUTH_SERVICE_URL=http://localhost:10101

# ── SSL ───────────────────────────────────────────────────
# USE_SSL=true activa el servidor HTTPS adicional en SSL_PORT
USE_SSL=false
SSL_PORT=20401
# Ruta donde están los certificados (server.crt / server.key o server.pfx)
CERT_PATH=/app/certs
SERVER_NAME=

# ── Kafka Audit Logger ────────────────────────────────────
# Broker(s) Kafka separados por coma
KAFKA_BROKER=localhost:9092
# Topic al que este servicio publica eventos de gateway
KAFKA_TOPIC=platform.logs
